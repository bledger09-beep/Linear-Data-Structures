using System;
using System.Collections.Generic;

class Program
{
    static void Main()
    {
        int n = int.Parse(Console.ReadLine());
        Stack<int> stack = new Stack<int>();

        // Read and push numbers onto the stack
        for (int i = 0; i < n; i++)
        {
            int number = int.Parse(Console.ReadLine());
            stack.Push(number);
        }

        // Pop and print numbers in reversed order
        while (stack.Count > 0)
        {
            Console.WriteLine(stack.Pop());
        }
    }
